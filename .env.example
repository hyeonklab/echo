# Echo backend environment variables (copy to .env and load before spring-boot:run)

# Database (optional overrides; defaults match docker-compose)
ECHO_DB_HOST=localhost
ECHO_DB_PORT=5432
ECHO_DB_NAME=echo
ECHO_DB_USER=echo
ECHO_DB_PASSWORD=echo

# JWT (minimum 32 bytes)
JWT_SECRET=change-me-to-a-random-secret-at-least-32-bytes-long

# OAuth2 clients
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# Frontend URL for OAuth redirect
FRONTEND_URL=http://localhost:3000
